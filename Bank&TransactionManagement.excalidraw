    {
      "id": "bTakU7i8okcJL7ZzVr-1N",
      "type": "text",
      "x": 2253.095238095239,
      "y": 1338.888888888889,
      "width": 937.0194091796875,
      "height": 800,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b00",
      "roundness": null,
      "seed": 1866380727,
      "version": 1203,
      "versionNonce": 703117625,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775518491930,
      "link": null,
      "locked": false,
      "text": " POST : /accounts/{accountId}/withdraw\n\n{/accounts/accountID/withdraw}\npublic Transaction withdraw(){\n    \n    User user = db.users.fetch({userId : \"userId\"}\n    //validate the user with JWT secret key, if not return to signup\n    if(!validated(user)) return 400 Bad Request with message signup required.\n\n      Account account  = db.accounts.fetch({accountID : \"accountID\"})\n      if(account.userId != User.userId) return bad request 401 Unauthorized\n\n      if(account.getBalance() < withdrawalamount) return 400 Bad Request \"Unsufficient Funds\"\n\n      //begin Transaction\n       \n        // lock account here as well because we are performing something here\n        //If Pure Read - No Lock Needed\n       //If read part of a write - Lock guarantees consistency\n        \n       account.balance -= withdrawal amount\n       db.account.save(account)\n        \n       Transaction txn = new Transaction(accountId)\n       db.transactions.save(txn)\n    \n    // commit\n\nif commit successful return 201 with transaction object\nif not return 500 internal server error or Bad request\n        \n}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": " POST : /accounts/{accountId}/withdraw\n\n{/accounts/accountID/withdraw}\npublic Transaction withdraw(){\n    \n    User user = db.users.fetch({userId : \"userId\"}\n    //validate the user with JWT secret key, if not return to signup\n    if(!validated(user)) return 400 Bad Request with message signup required.\n\n      Account account  = db.accounts.fetch({accountID : \"accountID\"})\n      if(account.userId != User.userId) return bad request 401 Unauthorized\n\n      if(account.getBalance() < withdrawalamount) return 400 Bad Request \"Unsufficient Funds\"\n\n      //begin Transaction\n       \n        // lock account here as well because we are performing something here\n        //If Pure Read - No Lock Needed\n       //If read part of a write - Lock guarantees consistency\n        \n       account.balance -= withdrawal amount\n       db.account.save(account)\n        \n       Transaction txn = new Transaction(accountId)\n       db.transactions.save(txn)\n    \n    // commit\n\nif commit successful return 201 with transaction object\nif not return 500 internal server error or Bad request\n        \n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
