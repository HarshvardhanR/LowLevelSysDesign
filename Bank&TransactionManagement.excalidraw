    {
      "id": "CBoomHKMfljXe1AxjIo5F",
      "type": "text",
      "x": 1011.3809523809532,
      "y": 1662.174603174604,
      "width": 1015.9393920898438,
      "height": 375,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0A",
      "roundness": null,
      "seed": 766141177,
      "version": 765,
      "versionNonce": 1595132153,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775518494746,
      "link": null,
      "locked": false,
      "text": "We might think why do we do extra checks such like that\n\nImagine a Scenario\n\nWhere A -> B and B -> A, it could lead to deadlock\n\nThread1 access the A account\nThread2 access the B account\n\nNow Thread1 wants B but locked by Thread2\n      Thread2 wants A but locked by Thread1\n\nThats why we are trying to lock the smaller UUID so both threads access the same account first.\nSo Thread2 sees the account has been locked it will be on hold until Thread1 completes its transaction\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We might think why do we do extra checks such like that\n\nImagine a Scenario\n\nWhere A -> B and B -> A, it could lead to deadlock\n\nThread1 access the A account\nThread2 access the B account\n\nNow Thread1 wants B but locked by Thread2\n      Thread2 wants A but locked by Thread1\n\nThats why we are trying to lock the smaller UUID so both threads access the same account first.\nSo Thread2 sees the account has been locked it will be on hold until Thread1 completes its transaction\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
