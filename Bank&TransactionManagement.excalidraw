    {
      "id": "4hJJJ-_PaY_plvbCOnc4J",
      "type": "text",
      "x": -174.53600783575212,
      "y": 1270.5555555555563,
      "width": 958.059326171875,
      "height": 1575,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b04",
      "roundness": null,
      "seed": 757290295,
      "version": 2471,
      "versionNonce": 1104556471,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "89OgOnPUUW1iKDOfd0yd-",
          "type": "arrow"
        }
      ],
      "updated": 1775518533962,
      "link": null,
      "locked": false,
      "text": "POST : /accounts/transfer\nBody : { \"sendingAccount\" : UUID, \"receivingAccount\" : UUID}\n\nIf we want to save the bandwidth we could pass the body contents in query strings as KV pair\n\n// this is not recommended it should be for idempotent reads, it should not change server's state\nPOST : /accounts/transfer?sendingAccount=UUID&receivingAccount=UUID\n\npublic Transaction transferSameUser(){\n    User user = db.users.fetch({userId : \"userId\"}\n    //validate the user with JWT secret key, if not return to signup\n    if(!validated(user)) return 400 Bad Request with message signup required.\n    \n    //begin Transaction\n\n    try{\n        Account first, second;\n\n        if (fromAccountId.compareTo(toAccountId) < 0) {\n            first = db.accounts.fetch(fromAccountId);\n            second = db.accounts.fetch(toAccountId);\n        } else {\n            first = db.accounts.fetch(toAccountId);\n            second = db.accounts.fetch(fromAccountId);\n        }\n\n        // Map correctly\n        Account sender = first.accountId.equals(fromAccountId) ? first : second;\n        Account receiver = first.accountId.equals(toAccountId) ? first : second;\n\n\n\n        if(sender.userID!=user.userID && receiver.userID!=user.userID) throw IDNotMatched\n\n        if(sender.getBalance() < transferAmount) throw InsufficientBalance Exception\n\n        sender.balance -= transferAmount\n        receiver.balance += transferAmount\n\n        db.accounts.save(sender)\n        db.accounts.save(receiver)\n\n        Transaction txn = new Transaction(receiver);\n        db.transactions.save(txn)\n        \n        db.commit()\n        return 201 with transaction Object\n        \n    }\n    catch (IDNotMatched Exception){\n        db.rollback()\n        return 400 with \"id not matched\"\n    }\n    catch(InsufficientBalance){\n        db.rollback()\n        return 400 with \"Insufficient Balalnce\"\n    }\n    catch(Exception){\n        db.rollback()\n        return 500 internal server error\n    }\n    \n}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "POST : /accounts/transfer\nBody : { \"sendingAccount\" : UUID, \"receivingAccount\" : UUID}\n\nIf we want to save the bandwidth we could pass the body contents in query strings as KV pair\n\n// this is not recommended it should be for idempotent reads, it should not change server's state\nPOST : /accounts/transfer?sendingAccount=UUID&receivingAccount=UUID\n\npublic Transaction transferSameUser(){\n    User user = db.users.fetch({userId : \"userId\"}\n    //validate the user with JWT secret key, if not return to signup\n    if(!validated(user)) return 400 Bad Request with message signup required.\n    \n    //begin Transaction\n\n    try{\n        Account first, second;\n\n        if (fromAccountId.compareTo(toAccountId) < 0) {\n            first = db.accounts.fetch(fromAccountId);\n            second = db.accounts.fetch(toAccountId);\n        } else {\n            first = db.accounts.fetch(toAccountId);\n            second = db.accounts.fetch(fromAccountId);\n        }\n\n        // Map correctly\n        Account sender = first.accountId.equals(fromAccountId) ? first : second;\n        Account receiver = first.accountId.equals(toAccountId) ? first : second;\n\n\n\n        if(sender.userID!=user.userID && receiver.userID!=user.userID) throw IDNotMatched\n\n        if(sender.getBalance() < transferAmount) throw InsufficientBalance Exception\n\n        sender.balance -= transferAmount\n        receiver.balance += transferAmount\n\n        db.accounts.save(sender)\n        db.accounts.save(receiver)\n\n        Transaction txn = new Transaction(receiver);\n        db.transactions.save(txn)\n        \n        db.commit()\n        return 201 with transaction Object\n        \n    }\n    catch (IDNotMatched Exception){\n        db.rollback()\n        return 400 with \"id not matched\"\n    }\n    catch(InsufficientBalance){\n        db.rollback()\n        return 400 with \"Insufficient Balalnce\"\n    }\n    catch(Exception){\n        db.rollback()\n        return 500 internal server error\n    }\n    \n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
