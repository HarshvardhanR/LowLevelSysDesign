    {
      "id": "V-NEnzGOgb66HePzQ6oHn",
      "type": "text",
      "x": 1732.3809523809516,
      "y": 234.3650793650794,
      "width": 888.2193603515625,
      "height": 825,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "al",
      "roundness": null,
      "seed": 1255235289,
      "version": 2450,
      "versionNonce": 521822937,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775518474880,
      "link": null,
      "locked": false,
      "text": "User want to deposit money\n\nPOST : /accounts/{accountID}/deposit\n\nThis endpoint needs to be protected, use JWT or some authentication object\n\n{/accounts/{accountID}/deposit}\npublic Transcation deposit(){\n    \n    User user = db.users.fetch({userId : \"userId\"}\n    //validate the user with JWT secret key, if not return to signup\n    if(!validated(user)) return 400 Bad Request with message signup required.\n\n      Account account  = db.accounts.fetch({accountID : \"accountID\"})\n      if(account.userId != User.userId) return bad request 401 Unauthorized\n\n      double amount = get the amount from Request Body\n      \n      int balance = account.getBalance()\n      balance += balance from Request Body\n    \n      db.accounts.save(account) // we don't have to worry about concurrency as database \n                                       locking happens on row level in PostgreSQL\n\n    // create a new transaction record in transaction table to record the entity\n    \n     Transaction txn = new Transaction(accountId)\n      \n    db.transactions.save(transaction)\n    \n\n    }\n}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "User want to deposit money\n\nPOST : /accounts/{accountID}/deposit\n\nThis endpoint needs to be protected, use JWT or some authentication object\n\n{/accounts/{accountID}/deposit}\npublic Transcation deposit(){\n    \n    User user = db.users.fetch({userId : \"userId\"}\n    //validate the user with JWT secret key, if not return to signup\n    if(!validated(user)) return 400 Bad Request with message signup required.\n\n      Account account  = db.accounts.fetch({accountID : \"accountID\"})\n      if(account.userId != User.userId) return bad request 401 Unauthorized\n\n      double amount = get the amount from Request Body\n      \n      int balance = account.getBalance()\n      balance += balance from Request Body\n    \n      db.accounts.save(account) // we don't have to worry about concurrency as database \n                                       locking happens on row level in PostgreSQL\n\n    // create a new transaction record in transaction table to record the entity\n    \n     Transaction txn = new Transaction(accountId)\n      \n    db.transactions.save(transaction)\n    \n\n    }\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
