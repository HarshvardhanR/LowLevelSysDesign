    {
      "id": "T8xfIavDfLXcokH5LQfq4",
      "type": "text",
      "x": 535.9642857142851,
      "y": 236.38888888888903,
      "width": 1017.7393798828125,
      "height": 500,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aV",
      "roundness": null,
      "seed": 1693484025,
      "version": 594,
      "versionNonce": 107655481,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775518470329,
      "link": null,
      "locked": false,
      "text": "User want to Create Account\nPOST : /accounts\n\n{/accounts}\npublic Account createAccount(){\n    if(JWT doesn't exist) return to signUp\n    if(not validated the body) return 400 Bad Request\n\n    //get The User\n    User user = db.fetch({userID : \"userID\"}) // you can get userID from authentication object or JWT\n    \n    Account account = new Account(User)    \n    \n    db.accounts.save(account)\n    \n    return 201 with User object if created.\n    return 400 if not created as a bad request\n    \n}\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "User want to Create Account\nPOST : /accounts\n\n{/accounts}\npublic Account createAccount(){\n    if(JWT doesn't exist) return to signUp\n    if(not validated the body) return 400 Bad Request\n\n    //get The User\n    User user = db.fetch({userID : \"userID\"}) // you can get userID from authentication object or JWT\n    \n    Account account = new Account(User)    \n    \n    db.accounts.save(account)\n    \n    return 201 with User object if created.\n    return 400 if not created as a bad request\n    \n}\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
